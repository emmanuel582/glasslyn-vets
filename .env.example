# ============================================
# Glasslyn Vets — AI Voice Receptionist Config
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# === Retell AI ===
# Get your API key from https://dashboard.retellai.com
RETELL_API_KEY=key_378467ea2cfb07c937c546e7f1fas

# Agent ID for inbound calls (created in Retell dashboard)
RETELL_AGENT_ID=agent_78d80b939040a78cb6ec1e75df

# Agent ID for outbound vet notification calls (created in Retell dashboard)
RETELL_OUTBOUND_AGENT_ID=agent_16dff092b7d1cf8eb355d2fb45

# Your phone number imported/purchased in Retell (E.164 format)
RETELL_FROM_NUMBER=+353xxxxxxxxxx

# Webhook secret for verifying Retell requests (from Retell dashboard)
RETELL_WEBHOOK_SECRET=key_8a199c6cffef7d7f1032b403a8e7

# === WPP Connect (WhatsApp) ===
# Session name for WPP Connect (no spaces, lowercase)
WPP_SESSION_NAME=glasslyn-vets

# === On-Call Vet Contacts ===
# Vet 1 (First Responder)
VET_1_NAME=Dr. O'Connor
VET_1_PHONE=353238841404

# Vet 2
VET_2_NAME=Dr. Murphy
VET_2_PHONE=353214772277

# Vet 3
VET_3_NAME=Dr. Kelly
VET_3_PHONE=3532641055

# Vet 4
VET_4_NAME=Dr. Byrne
VET_4_PHONE=353238845206

# === Server Configuration ===
# Port the Express server listens on
PORT=3000

# Public URL where this server is accessible (for Retell webhooks)
# Since you are running on a VPS, use your VPS IP address:
BASE_URL=http://187.124.55.32:3000

# === Clinic Details ===
CLINIC_NAME=Glasslyn Vets
CLINIC_PHONE=+353xxxxxxxxxx

# === Escalation Settings ===
# Minutes to wait for vet response before escalating
ESCALATION_TIMEOUT_MINUTES=15

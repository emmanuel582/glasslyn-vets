# ============================================
# Glasslyn Vets — Environment Variables Template
# ============================================
# Multi-Clinic Edition — 4 locations, per-clinic vet routing
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Retell AI ===
# Get your API key from https://dashboard.retellai.com
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_OUTBOUND_AGENT_ID=
RETELL_FROM_NUMBER=
RETELL_WEBHOOK_SECRET=

# === WPP Connect (WhatsApp) ===
WPP_SESSION_NAME=glasslyn-vets

# === Clinic Locations ===
# Each clinic has a name and a DID (the inbound phone number callers dial).
# The backend resolves the dialled number to the correct clinic and its vet group.

# Clinic 1
CLINIC_1_NAME=Glasslyn Main
CLINIC_1_DID=+353XXXXXXXXX1

# Clinic 2
CLINIC_2_NAME=Glasslyn Southside
CLINIC_2_DID=+353XXXXXXXXX2

# Clinic 3
CLINIC_3_NAME=Glasslyn Northside
CLINIC_3_DID=+353XXXXXXXXX3

# Clinic 4
CLINIC_4_NAME=Glasslyn West
CLINIC_4_DID=+353XXXXXXXXX4

# === Default Vet Contacts (seeded into DB on first run) ===
# These are ONLY used to seed the database initially.
# After first run, manage vets via the dashboard or API.
# Format: VET_{N}_NAME, VET_{N}_PHONE, VET_{N}_CLINIC (clinic number 1-4)
VET_1_NAME=Dr. Smith
VET_1_PHONE=+353XXXXXXXXX
VET_1_CLINIC=1

VET_2_NAME=Dr. Jones
VET_2_PHONE=+353XXXXXXXXX
VET_2_CLINIC=1

VET_3_NAME=Dr. Brown
VET_3_PHONE=+353XXXXXXXXX
VET_3_CLINIC=2

VET_4_NAME=Dr. Wilson
VET_4_PHONE=+353XXXXXXXXX
VET_4_CLINIC=2

VET_5_NAME=Dr. Taylor
VET_5_PHONE=+353XXXXXXXXX
VET_5_CLINIC=3

VET_6_NAME=Dr. Davis
VET_6_PHONE=+353XXXXXXXXX
VET_6_CLINIC=3

VET_7_NAME=Dr. Clark
VET_7_PHONE=+353XXXXXXXXX
VET_7_CLINIC=4

VET_8_NAME=Dr. Hall
VET_8_PHONE=+353XXXXXXXXX
VET_8_CLINIC=4

# === Server Configuration ===
PORT=3000
BASE_URL=http://YOUR_VPS_IP:3000

# === Escalation Settings ===
# Minutes to wait for vet response before escalating
ESCALATION_TIMEOUT_MINUTES=15
